package br.ufersa.edu;

import br.ufersa.edu.Cliente;
import java.time.LocalDate;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

public class Venda extends Cliente {
    private int id;
    private List<Item> itens;
    private int qtd;
    private LocalDate data;
    private boolean cancelada;

    public Venda(int id, LocalDate data, String nomeCliente, int cpfCliente, String enderecoCliente) {
        super(nomeCliente, cpfCliente, enderecoCliente);
        setId(id);
        setData(data);
        this.itens = new ArrayList<>();
        this.qtde = 0;
        this.cancelada = false;
    }

    public int getId(){
        return id;
    }

    public LocalDate getData(){
        return data;
    }

    public List<Item> getItens(){
        return Collections.unmodifiableList(itens);
    }

    public int getQtd(){
        return qtd;
    }

    public void setId(){
        if(id == null){
            System.out.println("ID inválido");
        }
        else {
            this.id = id;
        }
    }

    public void setData(LocalDate data){
        if (data == null){
            System.out.println("Data inválida");
        }
        else{
            this.data = LocalDate.now();
        }
    }

    public boolean Cancelada(){
        return cancelada;
    }

    public void adicionarItem(Item item) {
        if (cancelada){
            System.out.println("Venda cancelada");
        }

        if (item == null){
            System.out.println("Não tem nenhum item");
        }

        itens.add(item);
        qtde += item.getQuantidade();
    }

    public void removerItem(Item item) {
        if (cancelada){
            System.out.println("Venda cancelada");
        }

        itens.remove(item);
        qtde -= item.getQuantidade();
    }

    public double calcularTotal() {
        return itens.stream().mapToDouble(Item::calcularSubtotal).sum();
    }

    public void cancelar() {
        this.cancelada = true;
    }
}