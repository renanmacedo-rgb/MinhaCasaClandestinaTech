package br.ufersa.edu;

import br.ufersa.edu.Equipamento;
import java.util.ArrayList;

public class Estoque extends Equipamento{
    private ArrayList<Equipamento> equipamentos;

    public Estoque(){
        super("ESTOQUE", 0, 0.0, 0, Local.SISTEMA, Responsavel.SISTEMA);
        equipamentos = new ArrayList<>();
    }


    public void adicionar(Equipamento e){
        if (e == null){
            System.out.println("Equipamento inválido");
        }

        for (Equipamento eq : equipamentos){
            if (eq.getNumeroDeSerie() == e.getNumeroDeSerie()){
                System.out.println("Número de série já existe.");
            }
        }
        equipamentos.add(e);
    }

    public void remover(Equipamento e){
        equipamentos.remove(e);
    }

    public Equipamento buscarPorNome(String nome) {
        for (Equipamento eq : equipamentos){
            if (eq.getNome().equalsIgnoreCase(nome)){
                return eq;
            }
        }
        return null;
    }

    public Equipamento buscarPorNumeroSerie(int numeroSerie) {
        for (Equipamento eq : equipamentos){
            if (eq.getNumeroDeSerie() == numeroSerie){
                return eq;
            }
        }
        return null;
    }

    public ArrayList<Equipamento> buscarPorLocal(Local local) {
        ArrayList<Equipamento> resultado = new ArrayList<>();
        for (Equipamento eq : equipamentos){
            if (eq.getLocal().equals(local)){
                resultado.add(eq);
            }
        }
        return resultado;
    }

    public ArrayList<Equipamento> buscarPorResponsavel(Responsavel responsavel) {
        ArrayList<Equipamento> resultado = new ArrayList<>();
        for (Equipamento eq : equipamentos){
            if (eq.getResponsavel().equals(responsavel)){
                resultado.add(eq);
            }
        }
        return resultado;
    }

    public void gerarRelatorio() {
        if (equipamentos.isEmpty()){
            System.out.println("Estoque vazio");
            return null;
        }
        System.out.println("Relatório do Estoque:");
        for (Equipamento eq : equipamentos){
            System.out.println(eq);
        }
    }


    public ArrayList<Equipamento> getEquipamentos(){
        return new ArrayList<>(equipamentos);
    }
}